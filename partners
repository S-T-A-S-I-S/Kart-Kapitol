<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Kart Kapitol — Partners</title>
  <link rel="stylesheet" href="styles.css" />
</head>

<body>
  <div id="pageTransition" class="page-transition" aria-hidden="true"></div>
  <a class="skip-link" href="#main">Skip to content</a>

  <header class="site-header">
    <div class="container header-inner">
      <div class="brand">
        <div class="brand-text"><span class="brand-title">Kart Kapitol</span></div>
      </div>

      <nav class="nav" aria-label="Primary">
        <a href="index.html">Home</a>
        <a href="exhibits.html">Exhibits</a>
        <a href="events.html">Events</a>
        <a href="visit.html">Visit</a>
        <a href="partners.html" class="is-active">Partners</a>
      </nav>

      <button class="nav-toggle" aria-label="Open menu" aria-controls="mobileNav" aria-expanded="false">
        <span class="burger" aria-hidden="true"></span>
        <span class="sr-only">Menu</span>
      </button>
    </div>

    <div id="mobileNav" class="mobile-nav" hidden>
      <div class="container mobile-nav-inner">
        <a href="index.html" class="mobile-link">Home</a>
        <a href="exhibits.html" class="mobile-link">Exhibits</a>
        <a href="events.html" class="mobile-link">Events</a>
        <a href="visit.html" class="mobile-link">Visit</a>
        <a href="partners.html" class="mobile-link is-active">Partners</a>
      </div>
    </div>
  </header>

  <main id="main">
    <section class="hero">
      <div class="hero-media" aria-hidden="true">
        <img src="assets/kapitol.jpeg" alt="" />
      </div>
      <div class="kart-streak" aria-hidden="true"></div>

      <div class="container hero-content">
        <h1>Partners</h1>
        <p class="lead">
          Esports is a tourism story when the community builds it together — venues, sponsors, schools, and local business.
        </p>

        <div class="hero-actions">
          <button class="btn primary" data-open-modal="contact">Partner with us</button>
          <a class="btn ghost" href="events.html">See events</a>
        </div>

        <div class="hero-badges" aria-label="Partner highlights">
          <div class="badge"><span class="badge-top">Impact</span><span class="badge-bottom">Community</span></div>
          <div class="badge"><span class="badge-top">Growth</span><span class="badge-bottom">Tourism</span></div>
          <div class="badge"><span class="badge-top">Support</span><span class="badge-bottom">Events</span></div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container split">
        <div>
          <h2>Why Partners Matter</h2>
          <p>
            Kart Kapitol exists to spotlight Marshalltown’s esports ecosystem as a living portfolio.
            Partnerships turn events into visitor experiences—something the town can be proud of and share.
          </p>

          <ul class="checklist">
            <li>Creates repeatable showcase weekends</li>
            <li>Supports youth programs + education pathways</li>
            <li>Builds local business involvement</li>
            <li>Generates shareable media and town identity</li>
          </ul>
        </div>

        <div class="panel">
          <h3>Ways to partner</h3>
          <a class="panel-link" href="events.html">Sponsor an event</a>
          <a class="panel-link" href="visit.html">Host a visitor stop</a>
          <button class="panel-link btn-inline" data-open-modal="contact">Contact / inquiry</button>
        </div>
      </div>
    </section>

    <section class="section alt">
      <div class="container">
        <div class="section-head">
          <h2>Partnership Tracks</h2>
          <p>Pick a lane — keep it easy for local orgs to plug in.</p>
        </div>

        <div class="grid cards">
          <article class="card">
            <h3>Venue Partner</h3>
            <p>Provide space for events, watch parties, showcases, or workshops.</p>
            <button class="btn secondary" data-open-modal="contact">Start here</button>
          </article>

          <article class="card">
            <h3>Sponsor</h3>
            <p>Support production, prizes, promotion, or travel/tourism moments.</p>
            <button class="btn secondary" data-open-modal="contact">Sponsor inquiry</button>
          </article>

          <article class="card">
            <h3>Community Partner</h3>
            <p>Help connect youth programs, schools, and community engagement.</p>
            <button class="btn secondary" data-open-modal="contact">Partner inquiry</button>
          </article>

          <article class="card accent">
            <h3>Signature Event Partner</h3>
            <p>Build one “big wall” event each season that visitors can plan around.</p>
            <button class="btn primary" data-open-modal="contact">Let’s build it</button>
          </article>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-head">
          <h2>Press / Media</h2>
          <p>Make it easy for people to talk about Marshalltown.</p>
        </div>

        <div class="grid two">
          <div class="card">
            <h3>Media kit</h3>
            <p>Story angles, shareable descriptions, and assets.</p>
            <button class="btn secondary" data-open-modal="press">Open press kit</button>
          </div>

          <div class="card">
            <h3>Curator’s note</h3>
            <p>What Kart Kapitol is and how it functions as a city portfolio.</p>
            <button class="btn secondary" data-open-modal="curator">Read</button>
          </div>
        </div>
      </div>
    </section>
  </main>

	<footer class="site-footer site-footer-rich">
	  <div class="container footer-stack">
		<div>
		  <p class="footer-brand">Kart Kapitol</p>
		  <p class="muted">A curated esports portfolio for Marshalltown.</p>
		</div>

		<div class="footer-links">
		  <a href="events.html">Events</a>
		  <a href="exhibits.html">Exhibits</a>
		  <a href="visit.html">Visit</a>
		  <a href="partners.html">Partners</a>
		</div>

		<div class="footer-admin">
		  <a class="btn ghost small" href="login.html">Team Sign In</a>
		</div>
	  </div>
	</footer>

  <dialog id="modal" class="modal">
    <form method="dialog" class="modal-card">
      <div class="modal-head">
        <h3 id="modalTitle">Modal</h3>
        <button class="btn ghost small" value="cancel" aria-label="Close">✕</button>
      </div>
      <div id="modalBody" class="modal-body"></div>
      <div class="modal-actions">
        <button class="btn secondary" value="cancel">Close</button>
      </div>
    </form>
  </dialog>

  <script src="app.js"></script>
</body>
</html>